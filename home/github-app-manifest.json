{
  "name": "dendritic-cli-auth",
  "url": "https://github.com/aspauldingcode/.dotfiles",
  "description": "Dendritic pass-backed gh CLI auth (researched manifest allowlist)",
  "public": true,
  "request_oauth_on_install": true,
  "hook_attributes": {
    "url": "https://example.com/dendritic-cli-auth-webhook",
    "active": false
  },
  "default_events": [],
  "default_permissions": {
    "actions": "write",
    "administration": "write",
    "checks": "write",
    "codespaces": "write",
    "contents": "write",
    "dependabot_secrets": "write",
    "deployments": "write",
    "discussions": "write",
    "environments": "write",
    "issues": "write",
    "metadata": "read",
    "packages": "write",
    "pages": "write",
    "pull_requests": "write",
    "repository_hooks": "write",
    "repository_projects": "admin",
    "secrets": "write",
    "security_events": "write",
    "statuses": "write",
    "vulnerability_alerts": "write",
    "workflows": "write",
    "members": "write",
    "organization_administration": "write",
    "organization_hooks": "write",
    "organization_packages": "write",
    "organization_plan": "read",
    "organization_projects": "admin",
    "organization_secrets": "write",
    "organization_self_hosted_runners": "write",
    "organization_user_blocking": "write",
    "emails": "write",
    "keys": "write",
    "followers": "write",
    "gpg_keys": "write",
    "interaction_limits": "write",
    "profile": "write",
    "starring": "write"
  }
}
